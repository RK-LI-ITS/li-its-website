      </div>
      <div class="footer-col">
        <h5>Leistungen</h5>
        <ul>
          <li><a href="/#leistungen">Systemintegration</a></li>
          <li><a href="/#leistungen">Softwareentwicklung</a></li>
          <li><a href="/#leistungen">Rechenzentrum</a></li>
          <li><a href="/#ki">KI-Projekte</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Unternehmen</h5>
        <ul>
          <li><a href="/#trust">Zertifikate</a></li>
          <li><a href="/#kontakt">Kontakt</a></li>
