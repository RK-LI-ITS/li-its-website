        <span class="footer-contact-label">E-Mail</span>
        <span class="footer-contact-value">info@li-its.de</span>
      </a>
    </div>
    <div class="footer-bottom">
      <div>© {year} L&amp;I IT-solutions GmbH &amp; Co. KG — Weinheim · München</div>
      <div>Werderstr. 4, 69469 Weinheim</div>
    </div>
