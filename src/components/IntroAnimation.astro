---
import Shield from './Shield.astro';
---
<div class="intro-stage" id="intro">
  <div class="intro-content">
    <div class="intro-logo">
      <Shield size={92} class="intro-shield" />
      <div class="intro-logo-text">
        <div class="intro-logo-word">L<span class="amp">&amp;</span>I IT-solutions</div>
      </div>
    </div>
    <div class="intro-tagline">Systemhaus · Softwareentwicklung · KI-Projekte</div>
    <h1 class="intro-headline intro-headline-1">
      KI-Entwicklung für <span class="italic">alle Branchen</span>
    </h1>
    <h1 class="intro-headline intro-headline-2">
      mit dem <span class="serif">Sicherheitsstandard</span>,<br>den Ihre Branche verlangt.
    </h1>
  </div>
  <div class="intro-hint" id="introHint">Klicken, um fortzufahren</div>
</div>
